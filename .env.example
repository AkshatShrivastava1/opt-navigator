# Copy to .env and fill in. NEVER commit your real .env.
# Required for Week 1 (ingest + retrieve + generate)
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional — observability (Block 6). Leave blank to skip Langfuse.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Models (defaults match config.py; 1536-dim embeddings = pgvector column)
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
